# =============================================================================
# Stellar Vision Service — Environment Variables
# =============================================================================

PORT=8002

# Cosine similarity threshold for face authentication.
# Higher = stricter matching. 0.85 is a good starting point.
SIMILARITY_THRESHOLD=0.85

# Gateway base URL — used to fetch/store face vectors from the user store
GATEWAY_URL=http://localhost:8080

# JWT secret — must match the gateway's JWT_SECRET
# Used to validate the auth token passed with enrolment requests
JWT_SECRET=
