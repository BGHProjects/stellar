# =============================================================================
# Stellar AI Service — Environment Variables
# =============================================================================

# Port this service listens on (gateway expects 8001 by default)
PORT=8001

# Anthropic API key — required
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Path to the canonical system config
# Relative to the services/ai/ directory
SYSTEM_CONFIG_PATH=../../config/system.json

# Model to use for the agent
# claude-3-5-haiku-20241022 is fast and cheap for an embedded chatbot
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Max tokens for agent responses
MAX_TOKENS=1024

# Gateway base URL — used by tools that need to query voyage data
GATEWAY_URL=http://localhost:8080
