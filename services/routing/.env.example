# =============================================================================
# Stellar Routing Service — Environment Variables
# =============================================================================

PORT=8003
DEBUG=False
SECRET_KEY=change-me-in-production

SYSTEM_CONFIG_PATH=../../config/system.json

# QAOA configuration
# Number of QAOA layers (p parameter). Higher = better approximation, slower.
QAOA_LAYERS=2

# Whether to use Qiskit's QAOA simulator (true) or fall back to classical
# nearest-neighbour heuristic (false). Set false if Qiskit install is slow.
USE_QAOA=true
