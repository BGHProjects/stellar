# =============================================================================
# Stellar Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# All variables exposed to the browser MUST be prefixed with VITE_
# =============================================================================

# Base URL of the Stellar Gateway API.
# The Vite dev server proxies /api requests to this URL.
VITE_API_URL=http://localhost:8080

# Set to "true" to enable mock mode — all API calls return fixture data.
# The orbital renderer, booking flow UI, and price calculations remain live.
# Use this for the Vercel frontend-only deployment.
VITE_MOCK_MODE=false
